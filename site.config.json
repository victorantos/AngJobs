{
  "site": {
    "title": "AngJobs",
    "url": "https://angjobs.com",
    "description": "Find your next hacker job from Hacker News monthly threads. Browse the latest tech jobs, remote positions, and startup opportunities.",
    "language": "en",
    "theme": "gazette",
    "favicon": "/media/public/favicon-simple.svg",
    "appleTouchIcon": "/media/public/icon-256.png",
    "socialImage": "/media/public/twitter-banner.png"
  },
  "collections": {
    "pages": {
      "path": "content/pages",
      "urlPattern": "/:slug/",
      "template": "page",
      "fields": [
        { "name": "title", "type": "text", "required": true },
        { "name": "description", "type": "text" },
        { "name": "draft", "type": "boolean", "default": false }
      ]
    },
    "jobs": {
      "path": "content/jobs",
      "urlPattern": "/jobs/:slug/",
      "template": "story",
      "listUrl": "/jobs/",
      "listTemplate": "list",
      "label": "Jobs",
      "sortBy": "date",
      "sortOrder": "desc",
      "pageSize": 20,
      "rss": true,
      "fields": [
        { "name": "title", "type": "text", "required": true },
        { "name": "date", "type": "date" },
        { "name": "author", "type": "text" },
        { "name": "authorUrl", "type": "text" },
        { "name": "byline", "type": "text" },
        { "name": "section", "type": "text" },
        { "name": "tags", "type": "list" },
        { "name": "draft", "type": "boolean", "default": false }
      ]
    }
  },
  "plugins": ["search", "api-form", "goatcounter"],
  "pluginOptions": {
    "api-form": {
      "forms": {
        "apply": {
          "path": "/jobapplicationsfromangjobs",
          "encoding": "form",
          "button": "Apply",
          "fields": [
            { "name": "name", "type": "text", "label": "Full name", "required": true },
            { "name": "email", "type": "email", "label": "Email", "required": true },
            { "name": "text", "type": "textarea", "label": "Message — include a link to your CV or portfolio" }
          ],
          "hidden": {
            "url": "https://angjobs.com{page.url}",
            "title": "{page.title}",
            "source": "{page.authorUrl}",
            "author": "{page.author}"
          },
          "success": "Application sent — the job poster will receive it by email."
        }
      }
    },
    "goatcounter": { "code": "angjobs" }
  },
  "services": {
    "backend": "https://api.victorantos.com"
  }
}
